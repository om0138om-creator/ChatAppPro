<?xml version="1.0" encoding="utf-8"?>
     1. activity_main.xml - الشاشة الرئيسية الكاملة
     ═══════════════════════════════════════════════════════════════ -->

<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_main"
    tools:context=".MainActivity">

    <!-- ════════════════════════════════════════════════════════════
         شاشة التحقق من رقم الهاتف (Phone Verification Screen)
         ════════════════════════════════════════════════════════════ -->
    
    <RelativeLayout
        android:id="@+id/verificationLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:background="@drawable/gradient_background"
        android:padding="24dp">

        <!-- Header Section -->
        <LinearLayout
            android:id="@+id/verificationHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_marginTop="-80dp"
            android:orientation="vertical"
            android:gravity="center">

            <!-- App Icon -->
            <androidx.cardview.widget.CardView
                android:layout_width="120dp"
                android:layout_height="120dp"
                app:cardCornerRadius="60dp"
                app:cardElevation="12dp"
                android:layout_marginBottom="24dp">

                <ImageView
                    android:id="@+id/headerIcon"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/app_logo"
                    android:scaleType="centerCrop"
                    android:padding="20dp"
                    android:background="@drawable/circle_gradient"/>

            </androidx.cardview.widget.CardView>

            <!-- Welcome Text -->
            <TextView
                android:id="@+id/headerTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="مرحباً بك!"
                android:textSize="32sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:fontFamily="@font/cairo_bold"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/headerSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="سجّل دخولك للبدء بالمحادثة"
                android:textSize="16sp"
                android:textColor="@color/white_80"
                android:fontFamily="@font/cairo_regular"
                android:layout_marginBottom="40dp"/>

        </LinearLayout>

        <!-- Input Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/inputCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/verificationHeader"
            android:layout_marginTop="40dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp"
            android:padding="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Phone Number Input -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/phoneInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="رقم الهاتف"
                    app:boxBackgroundMode="outline"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:boxStrokeColor="@color/primary"
                    app:hintTextColor="@color/primary"
                    app:startIconDrawable="@drawable/ic_phone"
                    app:startIconTint="@color/primary"
                    app:errorEnabled="true"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/phoneEditText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="phone"
                        android:textSize="16sp"
                        android:fontFamily="@font/cairo_regular"
                        android:textDirection="ltr"
                        android:hint="+966 5XXXXXXXX"
                        android:padding="16dp"/>

                </com.google.android.material.textfield.TextInputLayout>

                <!-- Instructions Text -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="سنرسل لك رمز التحقق عبر بوت تليجرام"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"
                    android:fontFamily="@font/cairo_regular"
                    android:gravity="center"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="24dp"/>

                <!-- Open Telegram Button -->
                <Button
                    android:id="@+id/openTelegramButton"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="فتح بوت تليجرام"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:fontFamily="@font/cairo_bold"
                    android:background="@drawable/button_telegram"
                    android:drawableStart="@drawable/ic_telegram"
                    android:drawablePadding="12dp"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"
                    android:elevation="4dp"
                    android:stateListAnimator="@animator/button_elevation"/>

                <!-- Verify Button -->
                <Button
                    android:id="@+id/verifyButton"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="التالي"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:fontFamily="@font/cairo_bold"
                    android:background="@drawable/button_primary"
                    android:drawableEnd="@drawable/ic_arrow_forward"
                    android:drawablePadding="12dp"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"
                    android:layout_marginTop="16dp"
                    android:elevation="4dp"
                    android:stateListAnimator="@animator/button_elevation"/>

                <!-- Progress Bar -->
                <ProgressBar
                    android:id="@+id/verificationProgressBar"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="center"
                    android:layout_marginTop="16dp"
                    android:indeterminateTint="@color/primary"
                    android:visibility="gone"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Privacy Notice -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:text="باستخدامك للتطبيق، فإنك توافق على شروط الخدمة وسياسة الخصوصية"
            android:textSize="12sp"
            android:textColor="@color/white_60"
            android:fontFamily="@font/cairo_regular"
            android:gravity="center"
            android:padding="16dp"/>

    </RelativeLayout>

    <!-- ════════════════════════════════════════════════════════════
         شاشة إدخال رمز OTP (OTP Input Screen)
         ════════════════════════════════════════════════════════════ -->
    
    <RelativeLayout
        android:id="@+id/otpLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:background="@drawable/gradient_background"
        android:padding="24dp">

        <!-- Back Button -->
        <ImageView
            android:id="@+id/otpBackButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_arrow_back"
            android:padding="12dp"
            android:tint="@color/white"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:layout_marginTop="16dp"/>

        <!-- Content Container -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_marginTop="-60dp"
            android:orientation="vertical"
            android:gravity="center">

            <!-- Lock Icon -->
            <ImageView
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:src="@drawable/ic_lock"
                android:tint="@color/white"
                android:layout_marginBottom="24dp"/>

            <!-- Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="رمز التحقق"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:fontFamily="@font/cairo_bold"
                android:layout_marginBottom="8dp"/>

            <!-- Phone Display -->
            <TextView
                android:id="@+id/otpPhoneDisplay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="أدخل الرمز المرسل إلى\n+966 XXXXXXXXX"
                android:textSize="14sp"
                android:textColor="@color/white_80"
                android:fontFamily="@font/cairo_regular"
                android:gravity="center"
                android:layout_marginBottom="40dp"/>

            <!-- OTP Input Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="32dp">

                    <!-- OTP Boxes -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:weightSum="6">

                        <EditText
                            android:id="@+id/otp1"
                            style="@style/OtpBoxStyle"
                            android:layout_weight="1"/>

                        <EditText
                            android:id="@+id/otp2"
                            style="@style/OtpBoxStyle"
                            android:layout_weight="1"/>

                        <EditText
                            android:id="@+id/otp3"
                            style="@style/OtpBoxStyle"
                            android:layout_weight="1"/>

                        <EditText
                            android:id="@+id/otp4"
                            style="@style/OtpBoxStyle"
                            android:layout_weight="1"/>

                        <EditText
                            android:id="@+id/otp5"
                            style="@style/OtpBoxStyle"
                            android:layout_weight="1"/>

                        <EditText
                            android:id="@+id/otp6"
                            style="@style/OtpBoxStyle"
                            android:layout_weight="1"/>

                    </LinearLayout>

                    <!-- Timer -->
                    <TextView
                        android:id="@+id/otpTimer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="إعادة الإرسال بعد 02:00"
                        android:textSize="13sp"
                        android:textColor="@color/primary"
                        android:fontFamily="@font/cairo_regular"
                        android:layout_gravity="center"
                        android:layout_marginTop="16dp"/>

                    <!-- Confirm Button -->
                    <Button
                        android:id="@+id/confirmOtpButton"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="تأكيد"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:fontFamily="@font/cairo_bold"
                        android:background="@drawable/button_primary"
                        android:layout_marginTop="24dp"
                        android:elevation="4dp"/>

                    <!-- Resend Button -->
                    <Button
                        android:id="@+id/resendOtpButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="إعادة إرسال الرمز"
                        android:textSize="14sp"
                        android:textColor="@color/primary"
                        android:fontFamily="@font/cairo_regular"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:layout_gravity="center"
                        android:layout_marginTop="8dp"/>

                    <!-- Progress Bar -->
                    <ProgressBar
                        android:id="@+id/otpProgressBar"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_gravity="center"
                        android:layout_marginTop="16dp"
                        android:indeterminateTint="@color/primary"
                        android:visibility="gone"/>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </RelativeLayout>

    <!-- ════════════════════════════════════════════════════════════
         شاشة إعداد الملف الشخصي (Profile Setup Screen)
         ════════════════════════════════════════════════════════════ -->
    
    <RelativeLayout
        android:id="@+id/profileSetupLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:background="@color/background_main">

        <!-- Header -->
        <LinearLayout
            android:id="@+id/profileHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/gradient_background"
            android:padding="24dp"
            android:paddingBottom="80dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="إعداد الملف الشخصي"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:fontFamily="@font/cairo_bold"
                android:layout_marginTop="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="أضف صورتك واسمك ليتعرف عليك الآخرون"
                android:textSize="14sp"
                android:textColor="@color/white_80"
                android:fontFamily="@font/cairo_regular"
                android:layout_marginTop="4dp"/>

        </LinearLayout>

        <!-- Content Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/profileHeader"
            android:layout_marginTop="-60dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp">

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fillViewport="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="32dp">

                    <!-- Profile Photo Section -->
                    <RelativeLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginBottom="32dp">

                        <!-- Profile Image -->
                        <de.hdodenhof.circleimageview.CircleImageView
                            android:id="@+id/profileImageView"
                            android:layout_width="140dp"
                            android:layout_height="140dp"
                            android:src="@drawable/default_avatar"
                            app:civ_border_width="4dp"
                            app:civ_border_color="@color/primary"/>

                        <!-- Camera Button -->
                        <androidx.cardview.widget.CardView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:layout_alignEnd="@id/profileImageView"
                            android:layout_alignBottom="@id/profileImageView"
                            app:cardCornerRadius="24dp"
                            app:cardElevation="4dp"
                            android:layout_marginEnd="4dp"
                            android:layout_marginBottom="4dp">

                            <ImageView
                                android:id="@+id/uploadPhotoButton"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:src="@drawable/ic_camera"
                                android:padding="12dp"
                                android:background="@drawable/circle_primary"
                                android:tint="@color/white"/>

                        </androidx.cardview.widget.CardView>

                    </RelativeLayout>

                    <!-- Username Input -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/usernameInputLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="اسم المستخدم"
                        app:boxBackgroundMode="outline"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxStrokeColor="@color/primary"
                        app:hintTextColor="@color/primary"
                        app:startIconDrawable="@drawable/ic_person"
                        app:startIconTint="@color/primary"
                        app:errorEnabled="true"
                        app:counterEnabled="true"
                        app:counterMaxLength="30"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/usernameEditText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPersonName|textCapWords"
                            android:textSize="16sp"
                            android:fontFamily="@font/cairo_regular"
                            android:maxLength="30"
                            android:padding="16dp"/>

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Bio Input -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/bioInputLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="نبذة عنك (اختياري)"
                        app:boxBackgroundMode="outline"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxStrokeColor="@color/primary"
                        app:hintTextColor="@color/primary"
                        app:startIconDrawable="@drawable/ic_info"
                        app:startIconTint="@color/primary"
                        app:counterEnabled="true"
                        app:counterMaxLength="100"
                        android:layout_marginTop="16dp"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/bioEditText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textMultiLine|textCapSentences"
                            android:textSize="16sp"
                            android:fontFamily="@font/cairo_regular"
                            android:maxLength="100"
                            android:minLines="2"
                            android:maxLines="3"
                            android:gravity="top|start"
                            android:padding="16dp"/>

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Complete Button -->
                    <Button
                        android:id="@+id/completeProfileButton"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="إكمال"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:fontFamily="@font/cairo_bold"
                        android:background="@drawable/button_primary"
                        android:layout_marginTop="32dp"
                        android:elevation="4dp"/>

                    <!-- Progress Bar -->
                    <ProgressBar
                        android:id="@+id/profileProgressBar"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_gravity="center"
                        android:layout_marginTop="16dp"
                        android:indeterminateTint="@color/primary"
                        android:visibility="gone"/>

                </LinearLayout>

            </ScrollView>

        </androidx.cardview.widget.CardView>

    </RelativeLayout>

    <!-- ════════════════════════════════════════════════════════════
         الشاشة الرئيسية - قائمة المحادثات (Main Chats Screen)
         ════════════════════════════════════════════════════════════ -->
    
    <RelativeLayout
        android:id="@+id/mainLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:background="@color/background_main">

        <!-- Custom Toolbar -->
        <RelativeLayout
            android:id="@+id/customToolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@drawable/gradient_background"
            android:elevation="4dp"
            android:padding="8dp">

            <!-- Profile Section -->
            <LinearLayout
                android:id="@+id/profileSection"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_alignParentStart="true"
                android:padding="4dp">

                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/userProfileImage"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/default_avatar"
                    app:civ_border_width="2dp"
                    app:civ_border_color="@color/white"/>

                <TextView
                    android:id="@+id/userNameText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chat App Pro"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:fontFamily="@font/cairo_bold"
                    android:layout_marginStart="12dp"
                    android:maxLines="1"
                    android:ellipsize="end"/>

            </LinearLayout>

            <!-- Action Buttons -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_alignParentEnd="true"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/searchIcon"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/ic_search"
                    android:padding="10dp"
                    android:tint="@color/white"
                    android:background="?attr/selectableItemBackgroundBorderless"/>

                <ImageView
                    android:id="@+id/menuIcon"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/ic_menu"
                    android:padding="10dp"
                    android:tint="@color/white"
                    android:background="?attr/selectableItemBackgroundBorderless"/>

            </LinearLayout>

        </RelativeLayout>

        <!-- Search Bar -->
        <androidx.cardview.widget.CardView
            android:id="@+id/searchCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/customToolbar"
            android:layout_margin="16dp"
            app:cardCornerRadius="25dp"
            app:cardElevation="4dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_search"
                    android:tint="@color/text_secondary"
                    android:layout_marginStart="8dp"/>

                <EditText
                    android:id="@+id/searchEditText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="البحث في المحادثات..."
                    android:textSize="15sp"
                    android:fontFamily="@font/cairo_regular"
                    android:background="@null"
                    android:padding="8dp"
                    android:layout_marginStart="8dp"/>

                <ImageView
                    android:id="@+id/clearSearchIcon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_close"
                    android:tint="@color/text_secondary"
                    android:visibility="gone"
                    android:layout_marginEnd="8dp"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Chats RecyclerView -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/chatsRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_below="@id/customToolbar"
            android:clipToPadding="false"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            tools:listitem="@layout/item_chat"/>

        <!-- No Chats Message -->
        <LinearLayout
            android:id="@+id/noChatsContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <ImageView
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:src="@drawable/ic_empty_chats"
                android:alpha="0.3"/>

            <TextView
                android:id="@+id/noChatsTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="لا توجد محادثات بعد"
                android:textSize="18sp"
                android:textColor="@color/text_secondary"
                android:fontFamily="@font/cairo_regular"
                android:layout_marginTop="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ابدأ محادثة جديدة بالضغط على زر +"
                android:textSize="14sp"
                android:textColor="@color/text_hint"
                android:fontFamily="@font/cairo_regular"
                android:layout_marginTop="8dp"/>

        </LinearLayout>

        <!-- Loading Progress -->
        <ProgressBar
            android:id="@+id/mainProgressBar"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_centerInParent="true"
            android:indeterminateTint="@color/primary"
            android:visibility="gone"/>

        <!-- New Chat FAB -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/newChatFab"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_alignParentBottom="true"
            android:layout_margin="24dp"
            android:src="@drawable/ic_add_chat"
            app:tint="@color/white"
            app:backgroundTint="@color/primary"
            app:fabSize="normal"
            app:elevation="6dp"
            app:pressedTranslationZ="12dp"
            app:rippleColor="@color/white_30"/>

    </RelativeLayout>

</RelativeLayout>


