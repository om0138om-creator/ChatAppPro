<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/chat_background"
    tools:context=".ChatActivity">

    <!-- Custom Chat Header -->
    <RelativeLayout
        android:id="@+id/chatHeader"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@drawable/gradient_background"
        android:elevation="4dp"
        android:padding="8dp">

        <!-- Back Button -->
        <ImageView
            android:id="@+id/backButton"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:src="@drawable/ic_arrow_back"
            android:padding="10dp"
            android:tint="@color/white"
            android:background="?attr/selectableItemBackgroundBorderless"/>

        <!-- Recipient Info -->
        <LinearLayout
            android:id="@+id/recipientInfo"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_toEndOf="@id/backButton"
            android:layout_toStartOf="@id/callButtons"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="8dp">

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/recipientProfileImage"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:src="@drawable/default_avatar"
                app:civ_border_width="2dp"
                app:civ_border_color="@color/white"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:id="@+id/recipientNameText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="اسم المستخدم"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:fontFamily="@font/cairo_bold"
                    android:maxLines="1"
                    android:ellipsize="end"/>

                <TextView
                    android:id="@+id/recipientStatusText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="متصل الآن"
                    android:textSize="12sp"
                    android:textColor="@color/white_80"
                    android:fontFamily="@font/cairo_regular"
                    android:maxLines="1"/>

            </LinearLayout>

        </LinearLayout>

        <!-- Call Buttons -->
        <LinearLayout
            android:id="@+id/callButtons"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_alignParentEnd="true"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/callButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_call"
                android:padding="10dp"
                android:tint="@color/white"
                android:background="?attr/selectableItemBackgroundBorderless"/>

            <ImageView
                android:id="@+id/videoCallButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_video_call"
                android:padding="10dp"
                android:tint="@color/white"
                android:background="?attr/selectableItemBackgroundBorderless"/>

            <ImageView
                android:id="@+id/menuButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_more_vert"
                android:padding="10dp"
                android:tint="@color/white"
                android:background="?attr/selectableItemBackgroundBorderless"/>

        </LinearLayout>

    </RelativeLayout>

    <!-- Messages Container -->
    <RelativeLayout
        android:id="@+id/messagesContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/chatHeader"
        android:layout_above="@id/inputContainer">

        <!-- Messages RecyclerView -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/messagesRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:scrollbars="vertical"
            tools:listitem="@layout/item_message_received"/>

        <!-- Typing Indicator -->
        <LinearLayout
            android:id="@+id/typingIndicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:layout_marginBottom="8dp"
            android:layout_marginStart="16dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="12dp"
            android:background="@drawable/bg_typing_indicator"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="يكتب..."
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:fontFamily="@font/cairo_regular"/>

            <ProgressBar
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginStart="8dp"
                android:indeterminateTint="@color/primary"/>

        </LinearLayout>

        <!-- Loading Progress -->
        <ProgressBar
            android:id="@+id/loadingProgressBar"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_centerInParent="true"
            android:indeterminateTint="@color/primary"
            android:visibility="gone"/>

        <!-- No Messages -->
        <TextView
            android:id="@+id/noMessagesText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="ابدأ المحادثة"
            android:textSize="16sp"
            android:textColor="@color/text_hint"
            android:fontFamily="@font/cairo_regular"
            android:visibility="gone"/>

    </RelativeLayout>

    <!-- Input Container -->
    <RelativeLayout
        android:id="@+id/inputContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="@color/white"
        android:elevation="8dp"
        android:padding="8dp">

        <!-- Reply Preview -->
        <LinearLayout
            android:id="@+id/replyPreviewContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_reply_preview"
            android:padding="12dp"
            android:layout_marginBottom="8dp"
            android:visibility="gone">

            <View
                android:layout_width="4dp"
                android:layout_height="match_parent"
                android:background="@color/primary"
                android:layout_marginEnd="12dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="الرد على:"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary"
                    android:fontFamily="@font/cairo_bold"/>

                <TextView
                    android:id="@+id/replyPreviewText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="نص الرسالة المرد عليها"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"
                    android:fontFamily="@font/cairo_regular"
                    android:maxLines="2"
                    android:ellipsize="end"
                    android:layout_marginTop="2dp"/>

            </LinearLayout>

            <ImageView
                android:id="@+id/cancelReplyButton"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_close"
                android:padding="6dp"
                android:tint="@color/text_secondary"
                android:background="?attr/selectableItemBackgroundBorderless"/>

        </LinearLayout>

        <!-- Message Input -->
        <RelativeLayout
            android:id="@+id/messageInputContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/replyPreviewContainer">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_toStartOf="@id/sendButton"
                android:layout_marginEnd="8dp"
                app:cardCornerRadius="25dp"
                app:cardElevation="2dp"
                android:layout_centerVertical="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="4dp">

                    <ImageView
                        android:id="@+id/emojiButton"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_emoji"
                        android:padding="8dp"
                        android:tint="@color/text_secondary"
                        android:background="?attr/selectableItemBackgroundBorderless"/>

                    <EditText
                        android:id="@+id/messageInput"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="اكتب رسالة..."
                        android:textSize="15sp"
                        android:fontFamily="@font/cairo_regular"
                        android:background="@null"
                        android:padding="12dp"
                        android:maxLines="5"
                        android:inputType="textMultiLine|textCapSentences"/>

                    <ImageView
                        android:id="@+id/attachButton"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_attach"
                        android:padding="8dp"
                        android:tint="@color/text_secondary"
                        android:background="?attr/selectableItemBackgroundBorderless"/>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Send Button -->
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/sendButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_send"
                app:tint="@color/white"
                app:backgroundTint="@color/primary"
                app:fabSize="mini"
                app:elevation="4dp"
                android:visibility="gone"/>

            <!-- Voice Button -->
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/voiceButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_mic"
                app:tint="@color/white"
                app:backgroundTint="@color/primary"
                app:fabSize="mini"
                app:elevation="4dp"/>

        </RelativeLayout>

    </RelativeLayout>

    <!-- Voice Recording Layout -->
    <RelativeLayout
        android:id="@+id/voiceRecordingLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="@color/white"
        android:elevation="8dp"
        android:padding="16dp"
        android:visibility="gone">

        <View
            android:id="@+id/recordingBackground"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_recording"
            android:alpha="0.1"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/micIcon"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_mic_recording"
                android:tint="@color/error"/>

            <TextView
                android:id="@+id/recordingTimeText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="00:00"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:fontFamily="@font/cairo_bold"
                android:layout_marginStart="16dp"/>

            <TextView
                android:id="@+id/slideToCancel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="← اسحب للإلغاء"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:fontFamily="@font/cairo_regular"/>

        </LinearLayout>

    </RelativeLayout>

</RelativeLayout>


